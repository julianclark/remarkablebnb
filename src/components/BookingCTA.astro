---
interface Props {
  airbnbUrl: string;
  stayTitle: string;
}

const { airbnbUrl, stayTitle } = Astro.props;
---

<div class="space-y-3">
  <!-- Primary: Book Direct -->
  <a
    href="/contact"
    class="group block w-full rounded-xl bg-[var(--color-alpine)] hover:bg-[var(--color-alpine-dark)] text-white px-5 py-4 transition-all duration-200 hover:shadow-lg hover:shadow-[var(--color-alpine)]/25 hover:-translate-y-0.5"
    id={`cta-direct-${stayTitle.toLowerCase().replace(/\s+/g, '-')}`}
  >
    <div class="flex items-center justify-between gap-3">
      <div class="min-w-0">
        <div class="font-bold text-lg leading-tight">Book Direct: Save 5%</div>
        <div class="text-sm text-white/80 mt-0.5">No platform fees, personal service</div>
      </div>
      <svg class="w-5 h-5 flex-shrink-0 text-white/60 group-hover:text-white group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </div>
  </a>

  <!-- Secondary: Book on Airbnb -->
  <a
    href={airbnbUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="group block w-full rounded-xl border-2 border-[var(--color-stone-light)] hover:border-[var(--color-slate-mid)] px-5 py-4 transition-all duration-200 hover:shadow-sm"
    id={`cta-airbnb-${stayTitle.toLowerCase().replace(/\s+/g, '-')}`}
  >
    <div class="flex items-center justify-between gap-3">
      <div class="min-w-0">
        <div class="font-semibold text-[var(--color-slate-deep)]">Book on Airbnb</div>
        <div class="text-sm text-[var(--color-slate-mid)] mt-0.5">AirCover protection, platform support</div>
      </div>
      <svg class="w-4 h-4 flex-shrink-0 text-[var(--color-slate-mid)] group-hover:text-[var(--color-slate-deep)] transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
    </div>
  </a>

  <!-- Honest comparison note -->
  <p class="text-xs text-[var(--color-slate-mid)] text-center px-4">
    Direct is cheaper and personal. Airbnb offers AirCover mediation. Choose what works for you.
  </p>
</div>
