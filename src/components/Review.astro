---
interface Props {
  quote: string;
  name: string;
  date: string;
  location?: string;
  original?: string;
  variant?: 'card' | 'plain';
}

const { quote, name, date, location = '', original = '', variant = 'card' } = Astro.props;
const attribution = [name, location, date].filter(Boolean).join(' · ');

const wrapClass =
  variant === 'card'
    ? 'rounded-2xl border border-[var(--color-stone-light)] dark:border-[var(--color-slate-mid)] bg-white dark:bg-[var(--color-slate-deep)] p-5'
    : '';
---

<figure class={wrapClass}>
  <div class="text-[var(--color-gold-dark)] text-sm mb-2" aria-hidden="true">★★★★★</div>
  {original && (
    <blockquote lang="und" class="text-sm leading-relaxed mb-2">“{original}”</blockquote>
  )}
  <blockquote class:list={['text-sm leading-relaxed text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]', original && 'italic']}>
    {original ? quote : `“${quote}”`}
  </blockquote>
  <figcaption class="mt-3 text-xs font-semibold text-[var(--color-slate-deep)] dark:text-white">{attribution}</figcaption>
</figure>
