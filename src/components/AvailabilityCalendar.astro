---
import { buildMonths, type DateRange } from '../lib/availability';

interface Props {
  bookedRanges: DateRange[];
  monthsToShow?: number;
}

const { bookedRanges, monthsToShow = 2 } = Astro.props;

const months = buildMonths(monthsToShow, bookedRanges, new Date());
const weekdayLabels = ['Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa', 'Su'];
---

<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
  {months.map((month) => (
    <div class="rounded-xl border border-[var(--color-stone-light)] dark:border-[var(--color-slate-mid)] p-4">
      <div class="text-sm font-semibold mb-3 text-center">{month.label}</div>
      <div class="grid grid-cols-7 gap-1 text-xs text-center text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">
        {weekdayLabels.map((w) => <div>{w}</div>)}
      </div>
      <div class="grid grid-cols-7 gap-1">
        {month.weeks.flatMap((week) =>
          week.map((day) =>
            day.inMonth ? (
              <div
                class:list={[
                  'aspect-square flex items-center justify-center rounded-lg text-xs',
                  day.isPast
                    ? 'text-[var(--color-slate-mid)]/30 dark:text-[var(--color-stone-warm)]/20'
                    : day.booked
                      ? 'bg-[var(--color-slate-mid)]/15 dark:bg-[var(--color-slate-mid)]/40 text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] line-through'
                      : 'bg-[var(--color-alpine)]/10 text-[var(--color-slate-deep)] dark:text-white font-medium'
                ]}
              >
                {day.day}
              </div>
            ) : (
              <div />
            )
          )
        )}
      </div>
    </div>
  ))}
</div>
<div class="flex items-center gap-4 mt-4 text-xs text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">
  <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-[var(--color-alpine)]/10 inline-block"></span> Available</span>
  <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-[var(--color-slate-mid)]/15 dark:bg-[var(--color-slate-mid)]/40 inline-block"></span> Booked</span>
</div>
