---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pages = await getCollection('manual');
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// Get all manual pages for sidebar navigation
const allPages = (await getCollection('manual')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={`${page.data.title} — Guest Manual`}
  description={`${page.data.title} guide for guests at Remarkable BnB, Hanley's Farm, Queenstown.`}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">
      <a href="/" class="hover:text-[var(--color-alpine)] transition-colors">Home</a>
      <span class="mx-2">›</span>
      <span>Guest Manual</span>
      <span class="mx-2">›</span>
      <span class="text-[var(--color-slate-deep)] dark:text-[var(--color-snow)]">{page.data.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      <!-- Sidebar nav -->
      <aside class="lg:col-span-1">
        <nav class="sticky top-24 space-y-1">
          <h3 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-3 px-3">Guest Manual</h3>
          {allPages.map((p) => (
            <a
              href={`/manual/${p.data.slug}`}
              class:list={[
                'flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                p.data.slug === page.data.slug
                  ? 'bg-[var(--color-alpine)]/10 text-[var(--color-alpine)]'
                  : 'text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] hover:bg-[var(--color-stone-light)]/50 dark:hover:bg-[var(--color-slate-mid)]/30',
              ]}
            >
              <span>{p.data.icon}</span>
              <span>{p.data.title}</span>
            </a>
          ))}
        </nav>
      </aside>

      <!-- Content -->
      <div class="lg:col-span-3">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">{page.data.icon}</span>
          <h1 class="text-3xl sm:text-4xl font-extrabold">{page.data.title}</h1>
        </div>

        <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4 prose-p:leading-relaxed prose-li:leading-relaxed">
          <Content />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
