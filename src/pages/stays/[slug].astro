---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import AmenityGrid from '../../components/AmenityGrid.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import Carousel from '../../components/Carousel.astro';
import { getCollection, render } from 'astro:content';
import { getGallery } from '../../lib/galleries';
import { env } from 'cloudflare:workers';

export const prerender = false;

const { slug } = Astro.params;
const stays = await getCollection('stays');
const stay = stays.find((s) => s.data.slug === slug);

if (!stay) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(stay);
const gallery = getGallery(stay.data.slug, stay.data.title);

let bookedRanges: { start: string; end: string }[] = [];
try {
  const { results } = await env.DB.prepare(
    'SELECT start_date, end_date FROM ical_events WHERE room = ? AND end_date >= date("now") ORDER BY start_date'
  )
    .bind(stay.data.slug)
    .all();
  bookedRanges = (results ?? []).map((r: any) => ({ start: r.start_date, end: r.end_date }));
} catch (err) {
  console.error('Failed to load availability:', err);
}
---

<BaseLayout
  title={stay.data.seoTitle}
  description={stay.data.seoDescription}
>
  <SchemaOrg stayName={stay.data.title} stayType={stay.data.type} />

  <!-- Hero -->
  <section class="relative h-[50vh] min-h-[350px] flex items-end overflow-hidden">
    <div class="absolute inset-0 bg-[var(--color-slate-deep)]">
      <img
        src={stay.data.heroImage}
        alt={stay.data.heroAlt}
        class="w-full h-full object-cover opacity-70"
        loading="eager"
        decoding="async"
      />
    </div>
    <div class="absolute inset-0 gradient-scrim"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-10 w-full">
      {stay.data.guestFavourite && (
        <span class="badge badge-gold mb-3">⭐ Guest Favourite · {stay.data.rating} from {stay.data.reviewCount} reviews</span>
      )}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-2 !text-white">{stay.data.title}</h1>
      <p class="text-lg text-white/80">{stay.data.tagline}</p>
    </div>
  </section>

  {gallery.length > 0 && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 sm:pt-16">
      <h2 class="text-2xl font-bold mb-6">Photos</h2>
      <Carousel images={gallery} id={`gallery-${stay.data.slug}`} />
    </div>
  )}

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 sm:pt-16">
    <h2 class="text-2xl font-bold mb-6">Availability</h2>
    <AvailabilityCalendar bookedRanges={bookedRanges} staySlug={stay.data.slug} stayType={stay.data.type} />
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Quick stats -->
        <div class="flex flex-wrap gap-4 mb-8 text-sm">
          <div class="flex items-center gap-2 bg-[var(--color-stone-light)]/50 dark:bg-[var(--color-slate-mid)]/30 rounded-full px-4 py-2">
            🛏️ <span class="font-medium">{stay.data.bedrooms} {stay.data.bedrooms === 1 ? 'bedroom' : 'bedrooms'}</span>
          </div>
          <div class="flex items-center gap-2 bg-[var(--color-stone-light)]/50 dark:bg-[var(--color-slate-mid)]/30 rounded-full px-4 py-2">
            🚿 <span class="font-medium">{stay.data.bathrooms} {stay.data.bathrooms === 1 ? 'bathroom' : 'bathrooms'}</span>
          </div>
          <div class="flex items-center gap-2 bg-[var(--color-stone-light)]/50 dark:bg-[var(--color-slate-mid)]/30 rounded-full px-4 py-2">
            👥 <span class="font-medium">Up to {stay.data.maxGuests} guests</span>
          </div>
          {stay.data.beds.map((bed) => (
            <div class="flex items-center gap-2 bg-[var(--color-stone-light)]/50 dark:bg-[var(--color-slate-mid)]/30 rounded-full px-4 py-2">
              🛏️ <span class="font-medium">{bed.count} {bed.type} {bed.count === 1 ? 'bed' : 'beds'}</span>
            </div>
          ))}
        </div>

        <!-- Content from markdown -->
        <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-p:text-[var(--color-slate-mid)] dark:prose-p:text-[var(--color-stone-warm)] prose-p:leading-relaxed">
          <Content />
        </div>

        <!-- Amenities -->
        <div class="mt-12">
          <h2 class="text-2xl font-bold mb-6">What's included</h2>
          <AmenityGrid amenities={stay.data.amenities} />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 space-y-6">
          <!-- Booking card -->
          <div class="rounded-2xl border border-[var(--color-stone-light)] dark:border-[var(--color-slate-mid)] bg-white dark:bg-[var(--color-slate-deep)] p-6 shadow-sm">
            <h3 class="text-lg font-bold mb-1">Book this stay</h3>
            <p class="text-sm text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-6">{stay.data.title} · Hanley's Farm</p>
            <BookingCTA airbnbUrl={stay.data.airbnbUrl} stayTitle={stay.data.title} />
          </div>

          <!-- Location callout -->
          <div class="rounded-2xl bg-[var(--color-stone-light)]/30 dark:bg-[var(--color-slate-mid)]/20 p-6">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-3">Location</h3>
            <ul class="space-y-2 text-sm text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">
              <li class="flex items-start gap-2">
                <span class="mt-0.5">🏔️</span>
                <span>The Remarkables — short drive</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-0.5">⛳</span>
                <span>Jack's Point Golf — walking distance</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-0.5">🛍️</span>
                <span>Remarkables Park — 5 min drive</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-0.5">🏙️</span>
                <span>Queenstown CBD — 15 min drive</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
