---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Holly and Julian to enquire about direct bookings at Remarkable BnB."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="text-center mb-12">
      <span class="badge badge-alpine mb-3">Enquiries & Direct Bookings</span>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4">Contact Holly & Julian</h1>
      <p class="text-[var(--color-slate-mid)] dark:text(--color-stone-warm) max-w-xl mx-auto">
        Have questions about the stays, availability, or planning your trip? Send us a message and we'll get right back to you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Contact Info -->
      <div class="md:col-span-1 space-y-6">
        <div class="rounded-xl border border-[var(--color-stone-light)] dark:border-[var(--color-slate-mid)] p-6 bg-white dark:bg-[var(--color-slate-deep)]">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-4">Direct Contact</h2>
          <div class="space-y-4">
            <div>
              <p class="text-xs text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">Your Hosts</p>
              <p class="text-sm font-medium">Holly & Julian</p>
            </div>
            <div>
              <p class="text-xs text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">Location</p>
              <p class="text-sm font-medium">Hanley's Farm, Queenstown, NZ</p>
            </div>
            <div>
              <p class="text-xs text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)]">Email Enquiries</p>
              <!-- Placeholder for email as per TODO -->
              <p class="text-sm font-medium text-[var(--color-alpine)]">stay@remarkablebnb.nz</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-[var(--color-stone-light)]/40 p-6 text-sm">
          <h3 class="font-bold mb-2">💡 Direct Booking Benefits</h3>
          <ul class="space-y-1.5 list-disc pl-5 marker:text-[var(--color-alpine)] text-[var(--color-slate-mid)]">
            <li>5% discount on Airbnb rates</li>
            <li>No platform service fees</li>
            <li>Returning guest loyalty rates</li>
            <li>More flexible check-in when available</li>
          </ul>
        </div>
      </div>

      <!-- Enquiry Form -->
      <div class="md:col-span-2">
        <div id="enquiry-form"></div>
        <div
          class="hidden rounded-xl border border-[var(--color-forest)]/40 bg-[var(--color-forest)]/10 p-4 mb-4 text-sm"
          id="enquiry-success"
          role="status"
        >
          <strong>Thanks, your enquiry is on its way.</strong> We'll get back to you soon. For anything urgent, email us at <a class="text-[var(--color-alpine)] underline" href="mailto:stay@remarkablebnb.nz">stay@remarkablebnb.nz</a>.
        </div>
        <div
          class="hidden rounded-xl border border-[var(--color-gold)]/40 bg-[var(--color-gold)]/10 p-4 mb-4 text-sm"
          id="enquiry-error"
          role="alert"
        >
          Sorry, something went wrong sending that. Please email us directly at <a class="text-[var(--color-alpine)] underline" href="mailto:stay@remarkablebnb.nz">stay@remarkablebnb.nz</a>.
        </div>

        <form
          class="space-y-4 rounded-xl border border-[var(--color-stone-light)] dark:border-[var(--color-slate-mid)] p-6 sm:p-8 bg-white dark:bg-[var(--color-slate-deep)]"
          id="enquiry-form-el"
          method="POST"
          action="/api/enquiry"
        >
          <h2 class="text-lg font-bold mb-4">Send an Enquiry</h2>

          <!-- Honeypot: hidden from users, catches bots -->
          <div class="hidden" aria-hidden="true">
            <label for="company">Company (leave blank)</label>
            <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">Your Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                class="w-full min-w-0 box-border font-sans rounded-lg border border-[var(--color-stone-light)] px-3 py-2 text-sm bg-white text-[var(--color-slate-deep)] placeholder:text-[var(--color-slate-mid)]/70 focus:ring-1 focus:ring-[var(--color-alpine)] focus:border-[var(--color-alpine)] focus:outline-none"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full min-w-0 box-border font-sans rounded-lg border border-[var(--color-stone-light)] px-3 py-2 text-sm bg-white text-[var(--color-slate-deep)] placeholder:text-[var(--color-slate-mid)]/70 focus:ring-1 focus:ring-[var(--color-alpine)] focus:border-[var(--color-alpine)] focus:outline-none"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="stay" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">Which Stay?</label>
              <select 
                id="stay" 
                name="stay" 
                class="w-full min-w-0 box-border font-sans rounded-lg border border-[var(--color-stone-light)] px-3 py-2 text-sm bg-white text-[var(--color-slate-deep)] placeholder:text-[var(--color-slate-mid)]/70 focus:ring-1 focus:ring-[var(--color-alpine)] focus:border-[var(--color-alpine)] focus:outline-none"
              >
                <option value="unit">Two Bedroom Unit</option>
                <option value="room">Guest Room</option>
                <option value="general">General Enquiry</option>
              </select>
            </div>
            <div>
              <label for="dates" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">Proposed Dates</label>
              <input 
                type="text" 
                id="dates" 
                name="dates" 
                placeholder="e.g. 15-20 Aug"
                class="w-full min-w-0 box-border font-sans rounded-lg border border-[var(--color-stone-light)] px-3 py-2 text-sm bg-white text-[var(--color-slate-deep)] placeholder:text-[var(--color-slate-mid)]/70 focus:ring-1 focus:ring-[var(--color-alpine)] focus:border-[var(--color-alpine)] focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-slate-mid)] dark:text-[var(--color-stone-warm)] mb-1">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="4" 
              required 
              placeholder="Tell us about your plans, guest numbers, or any specific questions..."
              class="w-full min-w-0 box-border font-sans rounded-lg border border-[var(--color-stone-light)] px-3 py-2 text-sm bg-white text-[var(--color-slate-deep)] placeholder:text-[var(--color-slate-mid)]/70 focus:ring-1 focus:ring-[var(--color-alpine)] focus:border-[var(--color-alpine)] focus:outline-none"
            ></textarea>
          </div>

          <div class="pt-2">
            <button
              type="submit"
              id="enquiry-submit"
              class="w-full box-border font-sans rounded-lg bg-[var(--color-alpine)] hover:bg-[var(--color-alpine-dark)] text-white px-4 py-3 font-semibold text-sm transition-colors cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Submit Enquiry
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    function initEnquiry() {
      const form = document.getElementById('enquiry-form-el') as HTMLFormElement | null;
      if (!form) return;

      const success = document.getElementById('enquiry-success');
      const errorBox = document.getElementById('enquiry-error');
      const submit = document.getElementById('enquiry-submit') as HTMLButtonElement | null;
      const params = new URLSearchParams(location.search);

      const fmt = (iso: string) =>
        new Date(iso + 'T00:00:00Z').toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', timeZone: 'UTC' });

      // Prefill from calendar deep-links (?stay=&date= or ?checkin=&checkout=)
      const stayParam = params.get('stay');
      if (stayParam) {
        const sel = form.elements.namedItem('stay') as HTMLSelectElement | null;
        if (sel && Array.from(sel.options).some((o) => o.value === stayParam)) sel.value = stayParam;
      }
      const checkin = params.get('checkin');
      const checkout = params.get('checkout');
      const single = params.get('date');
      const datesInput = form.elements.namedItem('dates') as HTMLInputElement | null;
      if (datesInput) {
        if (checkin && checkout) datesInput.value = `${fmt(checkin)} – ${fmt(checkout)}`;
        else if (single) datesInput.value = fmt(single);
      }

      // Show status banner if we came back from a no-JS POST redirect
      if (params.get('sent')) success?.classList.remove('hidden');
      if (params.get('error')) errorBox?.classList.remove('hidden');

      // Progressive enhancement: submit via fetch, no page reload
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        success?.classList.add('hidden');
        errorBox?.classList.add('hidden');
        if (submit) { submit.disabled = true; submit.textContent = 'Sending…'; }

        try {
          const res = await fetch('/api/enquiry', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form) as any)),
          });
          const data = await res.json().catch(() => ({ ok: res.ok }));
          if (data.ok) {
            form.reset();
            success?.classList.remove('hidden');
            success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else {
            errorBox?.classList.remove('hidden');
          }
        } catch {
          errorBox?.classList.remove('hidden');
        } finally {
          if (submit) { submit.disabled = false; submit.textContent = 'Submit Enquiry'; }
        }
      });
    }

    initEnquiry();
    document.addEventListener('astro:page-load', initEnquiry);
  </script>
</BaseLayout>
