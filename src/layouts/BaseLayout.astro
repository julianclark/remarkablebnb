---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage, canonicalUrl } = Astro.props;
const siteTitle = 'Remarkable BnB';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const desc = description || 'Accommodation at Holly and Julian\'s home in Hanley\'s Farm, Queenstown. Near The Remarkables ski field and Jack\'s Point golf course. Book direct and save.';
const canonical = canonicalUrl || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:site_name" content={siteTitle} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={desc} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    @import '../styles/global.css';
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Navigation (navy accent band) -->
  <header class="sticky top-0 z-50 backdrop-blur-md bg-[var(--color-slate-deep)]/95 border-b border-white/10">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group" id="nav-home">
        <span class="text-lg font-bold text-white group-hover:text-[var(--color-alpine)] transition-colors">
          Remarkable BnB
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/stays/two-bedroom-unit" class="text-sm font-medium text-white/80 hover:text-white transition-colors" id="nav-stays-unit">Stays</a>
        <a href="/reviews" class="text-sm font-medium text-white/80 hover:text-white transition-colors" id="nav-reviews">Reviews</a>
        <a href="/contact" class="text-sm font-medium text-white/80 hover:text-white transition-colors" id="nav-contact">Contact</a>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden p-2 rounded-lg text-white/80 hover:bg-white/10 transition-colors"
        id="mobile-menu-btn"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div class="md:hidden hidden border-t border-white/10" id="mobile-menu">
      <div class="px-4 py-3 space-y-1">
        <a href="/stays/two-bedroom-unit" class="block px-3 py-2 rounded-lg text-sm font-medium text-white/80 hover:bg-white/10">Two Bedroom Unit</a>
        <a href="/stays/guest-room" class="block px-3 py-2 rounded-lg text-sm font-medium text-white/80 hover:bg-white/10">Guest Room</a>
        <a href="/reviews" class="block px-3 py-2 rounded-lg text-sm font-medium text-white/80 hover:bg-white/10">Reviews</a>
        <a href="/contact" class="block px-3 py-2 rounded-lg text-sm font-medium text-white/80 hover:bg-white/10">Contact</a>
      </div>
    </div>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer (navy accent band) -->
  <footer class="bg-[var(--color-slate-deep)] text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Brand -->
        <div>
          <h3 class="text-lg font-bold mb-2 text-white">Remarkable BnB</h3>
          <p class="text-sm text-white/70">
            Under The Remarkables.<br />
            Holly & Julian, your hosts.
          </p>
        </div>

        <!-- Stays -->
        <div>
          <h4 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-3">Our Stays</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/stays/two-bedroom-unit" class="text-white/80 hover:text-white transition-colors">Two Bedroom Unit</a></li>
            <li><a href="/stays/guest-room" class="text-white/80 hover:text-white transition-colors">Guest Room</a></li>
          </ul>
        </div>

        <!-- Quick links -->
        <div>
          <h4 class="text-sm font-semibold uppercase tracking-wider text-white/60 mb-3">Quick Links</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/reviews" class="text-white/80 hover:text-white transition-colors">Reviews</a></li>
            <li><a href="/contact" class="text-white/80 hover:text-white transition-colors">Contact Us</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-white/10">
        <p class="text-xs text-white/60 text-center">
          &copy; {new Date().getFullYear()} Remarkable BnB. Hanley's Farm, Queenstown, New Zealand.
        </p>
      </div>
    </div>
  </footer>

  <!-- Mobile menu toggle script -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        menu.classList.toggle('hidden');
      });
    }
  </script>
</body>
</html>
